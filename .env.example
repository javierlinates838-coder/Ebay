# Google Gemini (REQUIRED for photo analysis — get free key below)
# https://aistudio.google.com/apikey
# Add in Vercel: Settings → Environment Variables → GEMINI_API_KEY → Redeploy
GEMINI_API_KEY=

# Optional: override vision model (default: gemini-2.5-flash with Google Search grounding)
# GEMINI_VISION_MODEL=gemini-2.5-flash
# Note: Photo analysis uses Google Search grounding (Lens-style). May incur search grounding fees on your Google AI bill.

# OpenAI (optional alternative to Gemini)
OPENAI_API_KEY=

# eBay Developer API (optional — market search + publish use demo data without these)
# https://developer.ebay.com/
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_REDIRECT_URI=http://localhost:3000/api/ebay/callback
EBAY_ENV=sandbox
EBAY_FULFILLMENT_POLICY_ID=
EBAY_PAYMENT_POLICY_ID=
EBAY_RETURN_POLICY_ID=

# PhotoRoom API (optional)
# https://www.photoroom.com/api
PHOTOROOM_API_KEY=

# Supabase (for cloud inventory storage)
# https://supabase.com/
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
